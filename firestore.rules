rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // 1. CORE AUTHENTICATION FUNCTIONS
    // ==========================================
    function isLoggedIn() { 
      return request.auth != null; 
    }
    function isOwner(userId) { 
      return isLoggedIn() && request.auth.uid == userId; 
    }
    function isAdmin() { 
      return isLoggedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true; 
    }

    // ==========================================
    // 2. GLOBAL ADMIN OVERRIDES
    // ==========================================
    match /{path=**}/verifications/{docId} { allow read: if isAdmin(); }
    match /{path=**}/upcomingRegistrations/{docId} { allow read: if isAdmin(); }
    match /{path=**}/participants/{docId} { allow read: if isAdmin(); }

    // ==========================================
    // 3. USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'wallet', 'bonusCredits']));
    }

    match /users/{userId}/notifications/{notifId} { allow read, write: if isOwner(userId) || isAdmin(); }
    match /users/{userId}/pendingPayment/{tournamentId} { allow read, write: if isOwner(userId) || isAdmin(); }
    match /users/{userId}/upcomingRegistrations/{docId} { allow read, write: if isOwner(userId) || isAdmin(); }
    match /users/{userId}/confirmedRegistrations/{docId} { allow read, write: if isOwner(userId) || isAdmin(); }
    match /users/{userId}/performanceHistory/{docId} { allow read, write: if isOwner(userId) || isAdmin(); }
    
    match /users/{userId}/wallet/{walletId} { 
      allow read: if isOwner(userId) || isAdmin(); 
      allow write: if isAdmin(); 
    }
    match /users/{userId}/transactions/{transId} { 
      allow read: if isOwner(userId) || isAdmin(); 
      allow write: if isAdmin(); 
    }

    // ==========================================
    // 4. TOURNAMENTS COLLECTION
    // ==========================================
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin(); 

      match /participants/{docId} {
        allow read: if isOwner(docId) || isAdmin();
        // ✅ FIX: Use .get() to prevent crashes if the field is missing
        allow create: if isOwner(docId) && request.resource.data.get('paymentStatus', '') != 'verified';
        allow update: if isAdmin() || (isOwner(docId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confirmationReceived', 'confirmedAt']));
      }
      
      match /verifications/{docId} { 
        allow read: if isOwner(docId) || isAdmin(); 
        allow create: if isOwner(docId) && request.resource.data.get('status', '') != 'approved';
        
        // ✅ FIX: Allows user to update their document and change status ONLY to 'pending' (for resubmissions)
        allow update: if isAdmin() || (isOwner(docId) && 
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['paymentStatus']) &&
          (request.resource.data.status == resource.data.status || request.resource.data.status == 'pending')
        );
        allow delete: if isOwner(docId) || isAdmin();
      }
      
      match /teamSessions/{teamId} { 
        allow read: if isLoggedIn(); 
        allow write: if isOwner(teamId) || isAdmin(); 
      }
      
      match /limitedNotifyList/{docId} { 
        allow read, write: if isOwner(docId) || isAdmin(); 
      }
      
      match /slots/{slotId} {
        allow read: if true; 
        allow write: if isAdmin(); 
      }

      match /leaderboard/{rankId} {
        allow read: if true; 
        allow write: if isAdmin(); 
      }

      match /upcomingRegistrations/{docId} {
        allow read: if isOwner(docId) || isAdmin();
        allow create: if isOwner(docId) 
                      && request.resource.data.get('paymentStatus', '') != 'verified' 
                      && request.resource.data.get('status', '') != 'approved';
        
        // ✅ FIX: Ensure users can ALSO resubmit upcoming registrations without permission errors
        allow update: if isAdmin() || (isOwner(docId) && 
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['paymentStatus']) &&
          (request.resource.data.status == resource.data.status || request.resource.data.status == 'pending')
        );
          
    allow delete: if isOwner(docId) || isAdmin();
      }

      match /lockedRegistrations/{docId} {
        allow read, write: if isOwner(docId) || isAdmin();
      }
    }

    // ==========================================
    // 5. TEAMS COLLECTION
    // ==========================================
    match /teams/{teamId} {
      allow read, create: if isLoggedIn();
      allow delete: if isAdmin();
      
      allow update: if isAdmin() || (isLoggedIn() && (
        resource.data.leaderId == request.auth.uid || 
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      ));
      
      match /wallet/{walletId} { 
        allow read: if isLoggedIn(); 
        allow write: if isAdmin(); 
      }
      
      // ✅ FIX 1: Allow team members to read their Financial Ledger
      match /transactions/{txId} {
        allow read: if isAdmin() || (isLoggedIn() && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members);
        allow write: if isAdmin();
      }
      
      // ✅ FIX 2: Allow anyone to read team tournament histories
      match /tournamentHistory/{docId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // ==========================================
    // 6. SYSTEM & ADMIN DATA
    // ==========================================
    match /adminNotifications/{notifId} { 
      allow create: if isLoggedIn(); 
      allow read, update, delete: if isAdmin(); 
    }
    
    match /reports/{reportId} { 
      allow create: if isLoggedIn(); 
      allow read, update, delete: if isAdmin(); 
    }
    
    match /calendarEvents/{eventId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    
  }
}
